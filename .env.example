# Copy this file to .env.local and fill in your own API key.
# Do not upload .env.local to Gitee or GitHub.

LLM_API_KEY=your_api_key_here
# If your computer already uses API_KEY, the program can read that too.
# API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_MODEL=qwen-plus

# ── Intelligence Enhancement (optional) ──
# Maximum self-reflection rounds per query (0 = disabled, 1 = default)
# MAX_REFLECTION_ROUNDS=1
# Enable query expansion with academic synonyms for better recall
# ENABLE_QUERY_EXPANSION=1
# Enable post-retrieval reranking for better precision
# ENABLE_RERANK=1
# Reciprocal Rank Fusion constant (higher = less weight on top ranks)
# RRF_K=60
